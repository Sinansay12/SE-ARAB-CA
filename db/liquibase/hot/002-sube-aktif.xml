<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="hot-002-sube-aktif" author="arabica">
        <addColumn tableName="sube" schemaName="hot">
            <column name="aktif" type="boolean" defaultValueBoolean="true"
                    remarks="Soft-deactivation flag — branches are never hard-deleted (preserves transfer history FK).">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="sube" schemaName="hot" columnName="aktif"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
