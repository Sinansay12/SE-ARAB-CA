<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="hist-001-transfer-emirleri" author="arabica">
        <createTable tableName="transfer_emirleri" schemaName="hist" remarks="Transfer orders (FR-9/FR-10) + audit archive">
            <column name="emir_id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_transfer_emirleri" nullable="false"/>
            </column>
            <column name="kaynak_sube_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="hedef_sube_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="tip" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="adet" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="durum" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="red_gerekcesi" type="varchar(500)"/>
            <column name="olusturulma_zamani" type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="transfer_emirleri" schemaName="hist" indexName="ix_transfer_durum">
            <column name="durum"/>
        </createIndex>
        <rollback>
            <dropTable tableName="transfer_emirleri" schemaName="hist"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
